ErrorDocument 404 /404.html
ErrorDocument 403 /403.html

RewriteEngine On

RewriteRule ^favicon\.png$ - [L]

RewriteCond %{HTTP_REFERER} ^$
RewriteRule \.(jpg|jpeg|png|gif|webp|glb|mp4|pdf|mp3)$ /refresh403.html [L]

RewriteCond %{HTTP_REFERER} !^https://remibertrand.net/ [NC]
RewriteCond %{HTTP_REFERER} !^https://www.remibertrand.net/ [NC]
RewriteRule \.(jpg|jpeg|png|gif|webp|glb|mp4|pdf|mp3)$ /refresh403.html [L]
